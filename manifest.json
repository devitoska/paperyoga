{
  "manifest_version": 2,
  "name": "PaperYoga",
  "version": "1.0",
  "description": "Quack quack",
  "browser_action": {
    "default_title": "PaperYoga",
    "default_popup": "menu/menu.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "paper@yo.ga"
    }
  },
  "icons": {
    "48": "icons/icon.png"
  },

  "content_scripts": [
    {
      "matches": ["*://scholar.google.com/scholar?*"],
      "js": ["js/libraries/jquery_min.js",
             "js/utils.js", "js/scholar.js", "js/scopus.js", "js/view.js", "js/content.js"],
      "css" : ["css/content.css"]
    }
  ],
  "background": {
    "scripts": ["js/background.js"]
  },

  "permissions": [
    "https://api.elsevier.com/*",
    "storage",
    "scripting",
    "activeTab"
  ],

  "web_accessible_resources": ["img/*", "icons/*", "html/*", "css/*", "js/*", "menu/*"]

}